<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">

    <!--
        RGX-Hello — the whole addon is one file. That is the point: with
        RGX-Framework's declarative RGXAddon front door, a real addon
        (saved settings, options panel, slash command, minimap button,
        event handling) does not need to be split across core/events/
        commands/config files. See data/core.lua.
    -->
    <Script file="data/core.lua"/>

</Ui>
